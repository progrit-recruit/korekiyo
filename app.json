{
  "expo": {
    "name": "コレキヨ",
    "slug": "korekiyo-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "korekiyo",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.korekiyo.app"
    },
    "android": {
      "package": "com.korekiyo.app",
      "adaptiveIcon": {
        "backgroundColor": "#FF6B6B",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-status-bar",
      "expo-secure-store",
      [
        "expo-camera",
        { "cameraPermission": "コレキヨが服の写真を撮るためにカメラを使用します" }
      ],
      [
        "expo-image-picker",
        { "photosPermission": "コレキヨが服の写真を選択するためにフォトライブラリを使用します" }
      ],
      [
        "expo-location",
        { "locationWhenInUsePermission": "コレキヨが現在地の天気を取得するために位置情報を使用します" }
      ]
    ]
  }
}
